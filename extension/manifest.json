{
  "manifest_version": 3,
  "name": "Blackboard Grade Harvester",
  "version": "2.0",
  "description": "Automatically collects all grades from UMBC Blackboard Ultra and exports them to Excel or JSON.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://blackboard.umbc.edu/*", 
    "http://localhost:8080/*"
    ],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://blackboard.umbc.edu/*"],
      "js": ["map.js", "content.js"]
    }
  ]
}